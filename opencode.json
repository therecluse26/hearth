{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "reflex": {
      "type": "local",
      "command": ["node_modules/.bin/rfx", "mcp"]
    },
"context-mode": {
      "type": "local",
      "command": ["node", "node_modules/context-mode/start.mjs"]
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "ask"
    }
  }
}