# Hearth environment variables — copy to .env and fill in real values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual credentials
#
# .env is loaded automatically when Hearth reads hearth.yaml from the same
# directory. Variables already set in the process environment take precedence
# over values defined here.
#
# NEVER commit .env to version control. It is listed in .gitignore.

# ---------------------------------------------------------------------------
# SMTP credentials
# ---------------------------------------------------------------------------
# Used by hearth.yaml when `email.transport: smtp` is set.
# Reference these in hearth.yaml as ${SMTP_HOST}, ${SMTP_USERNAME}, etc.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=starttls
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=Hearth <notifications@example.com>
