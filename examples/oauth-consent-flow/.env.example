# OAuth consent flow demo — client app environment variables.
#
# Copy to .env (same directory as this file) and adjust as needed.
# The client-ts/ app reads from the example directory's .env automatically.

# Base URL where the Hearth server is listening. Must match
# server.bind_address + server.port in hearth.yaml.
HEARTH_BASE_URL=http://localhost:8420

# Realm name the demo runs in. Must match the realm declared in
# hearth.yaml. Used for display + to derive deterministic client IDs.
HEARTH_REALM=demo

# Realm UUID. Find it on http://localhost:8420/ui/admin/realms after
# running the initial /ui/setup onboarding — or via the server's
# startup log, which prints realm IDs after reconciliation. Required
# because Hearth is realm-scoped and every API call carries X-Realm-ID.
HEARTH_REALM_ID=

# Port the client Express app binds to. If you change this, update the
# redirect_uris in hearth.yaml to match.
CLIENT_PORT=3000

# OAuth client IDs are NOT configured here — they are derived
# deterministically from (HEARTH_REALM, app_key) as UUID v5. See
# src/server.ts::clientIdFor and src/identity/reconcile.rs::APP_NAMESPACE.
