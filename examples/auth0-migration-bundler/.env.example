# Auth0 Management API credentials.
#
# Create an M2M application in the Auth0 dashboard, authorize it against the
# Management API, and grant the following scopes:
#   read:users                         (bulk user export)
#   read:user_idp_tokens               (optional — federated identity metadata)
#   read:clients                       (applications)
#   read:client_keys                   (plaintext client secrets — only if you
#                                       want to carry them over; omit to land
#                                       with Hearth-generated secrets)
#   read:organizations                 (organizations + members)
#   read:roles                         (realm roles + assignments)
#
# The bundler uses these exact three env vars; copy this file to .env and
# fill them in, or export them before running.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
