meta {
  name: Introspect Token
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/introspect
  body: json
  auth: none
}

headers {
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

body:json {
  {
    "token": "{{accessToken}}",
    "token_type_hint": "access_token",
    "client_id": "{{clientId}}"
  }
}
