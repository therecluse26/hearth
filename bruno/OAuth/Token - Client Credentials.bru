meta {
  name: Token - Client Credentials
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/token
  body: json
  auth: none
}

headers {
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

body:json {
  {
    "grant_type": "client_credentials",
    "client_id": "{{clientId}}",
    "client_secret": "your-client-secret",
    "scope": "openid"
  }
}
