meta {
  name: Token - Refresh
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/token
  body: json
  auth: none
}

headers {
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

body:json {
  {
    "grant_type": "refresh_token",
    "client_id": "{{clientId}}",
    "refresh_token": "{{refreshToken}}"
  }
}
