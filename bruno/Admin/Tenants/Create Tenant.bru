meta {
  name: Create Tenant
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/tenants
  body: json
  auth: bearer
}

headers {
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "acme-corp",
    "display_name": "Acme Corporation"
  }
}
