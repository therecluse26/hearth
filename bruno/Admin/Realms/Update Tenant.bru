meta {
  name: Update Realm
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/admin/realms/{{realmId}}
  body: json
  auth: bearer
}

headers {
  X-Realm-ID: {{realmId}}
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "display_name": "Acme Corporation (Updated)"
  }
}
