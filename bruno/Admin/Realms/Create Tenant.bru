meta {
  name: Create Realm
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/realms
  body: json
  auth: bearer
}

headers {
  X-Realm-ID: {{realmId}}
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "acme-corp",
    "display_name": "Acme Corporation"
  }
}
