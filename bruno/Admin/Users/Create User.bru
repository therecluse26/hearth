meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/users
  body: json
  auth: bearer
}

headers {
  X-Realm-ID: {{realmId}}
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "email": "bob@example.com",
    "display_name": "Bob",
    "password": "SecurePassword123!"
  }
}
