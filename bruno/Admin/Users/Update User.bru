meta {
  name: Update User
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/admin/users/{{userId}}
  body: json
  auth: bearer
}

headers {
  X-Tenant-ID: {{tenantId}}
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "display_name": "Bob Updated",
    "email": "bob-updated@example.com"
  }
}
